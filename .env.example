# Sorani Kurdish GEC — Environment Configuration
# ================================================
# Copy this file to .env and adjust values for your setup.
# The web UI reads SORANI_GEC_ROOT to locate the pipeline codebase.

# Root directory of the sorani-gec package (absolute path).
# Used by the web module to import src/ and locate configs/models.
SORANI_GEC_ROOT=/path/to/Implementation/sorani-gec

# Device for model inference (cuda, cuda:0, cpu).
# Overrides auto-detection when set.
# DEVICE=cuda

# Maximum input length in bytes for ByT5 inference.
# Must match the value used during training (default.yaml: 256).
# MAX_LENGTH=256

# Gradio web UI settings
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# Python I/O encoding — required for Kurdish text output in terminal.
# Set this in your shell before running scripts that print Kurdish text.
PYTHONIOENCODING=utf-8

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Model checkpoint paths (used by web/models.py and scripts/10_infer.py)
# BASELINE_MODEL_PATH=results/models/baseline/best_model.pt
# MORPHAWARE_MODEL_PATH=results/models/morphaware/best_model.pt

# ByT5 backbone variant (must match training; see configs/default.yaml)
# MODEL_BACKBONE=google/byt5-small

# Gradio web UI settings
# GRADIO_SERVER_PORT=7860
# GRADIO_SHARE=false
